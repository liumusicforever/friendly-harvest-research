                    &lt;li class=&quot;mb-2&quot;&gt;
                        &lt;span class=&#39;vis-earliest-custom mr-1&#39;&gt;&lt;/span&gt;Att Bażiku / L-ewwel data ta&amp;#39; dħul fis-seħħ
                    &lt;/li&gt;

                    &lt;li class=&quot;mb-2&quot;&gt;
