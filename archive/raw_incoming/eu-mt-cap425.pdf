<script>

    function loadVideoPartial(link) {

        var viewType = $(link).attr("data-view");
        $("#mainPanel").toggleClass("mainPanelTransition");

        $.post('/Home/LoadVideoPartial', { type: viewType }, function (result) {

            $("#mainPanel").html(result.data);
            $("#mainPanel").toggleClass("mainPanelTransition");

            //Scroll to top of the page if on mobile device.
            if (isUserOnMobile()) {
                window.scrollTo(0, 0);
            }
        });
    }

