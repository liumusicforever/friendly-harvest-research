</html>

<script>

    $(function () {

        $(document).ready(function () {
            $('#userProfileButton').hover(function () {
                $('#userProfileDropdown').removeClass('hide');
                $('#userProfileDropdown').addClass('show');
            }, function () {
                $('#userProfileDropdown').addClass('hide');
                $('#userProfileDropdown').removeClass('show');
            });
        });

        //Set tooltips.
        $('[data-toggle="tooltip"]').tooltip();

        //Search bar.
        $("#globalSearch").keydown(function (e) {

                                if (e.which === 13 && $("#globalSearch").val().trim() !== "") {

                $("#globalSearchParent").toggleClass("loading");
                $(".dontRemove #globalSearchSubmit").click();
                                }
                            });

        $("#globalSearch").keyup(function () {
            $("#search_SearchString").val($("#globalSearch").val());
                            });

        //Home btn.
        $("#homeButton").click(function () {
                                window.location.pathname = $(this).find("a").attr("href");
                            });

        //Header toggle.
        $("#navbarCollapseToggle1").click(function () {
            $("#navbarCollapseToggle2").click();
                            });

        //Remove video from DOM after modal is closed.
        $('#viewModal').on('hidden.bs.modal', function (e) {
            $("#videoModalBody").html("");
                            })

        //IE Explorer check.
        var isIE = false || !!document.documentMode;

        if (isIE === true) {

            toastr.error(
                'Internet Explorer is not supported, to continue using this site switch to Chrome/Firefox/Edge',
                "",
                {
                    "closeButton": false,
                    "positionClass": "toast-top-full-width",
                    "timeOut": "0",
                    "extendedTimeOut": "0",
                });
        }

        CheckForNotifications();
    });

    function HrefCancel() {
        var location = $(this).attr('href');
        window.location.href = location;
        return false;
    };

    function toggleSide(btn) {

        $("#mainSidePanel, #topLogoPanel").toggleClass("sideBarHidden");
        $(btn).find("i").toggleClass("fa-angle-left fa-angle-right");

        $("#mainSidePanel").hasClass("sideBarHidden") ? setCookie("sideBarHidden", "true") : setCookie("sideBarHidden", "false");
    }

    function globalSearchDone() {

        $("#globalSearchParent").toggleClass("loading");
        $("#mainPanel").css("margin-top", "-70px")
    }

    function alterDatatable() {

        $("#mainTable_length, #mainTable_filter").parent().toggleClass("col-sm-12 col-md-6 col-6");
        $("#mainTable_length").parent().addClass("d-flex m-auto");
    }

    function closeCookieDiv() {

        $("#cookieFooter").addClass("d-none");
        setCookie("cookiePromptShown", "true", 7);
    }

     function MarkAsReadAndViewDocument(element, notificationId, url) {
         var baseUrl = window.location.origin
             ? window.location.origin + '/'
             : window.location.protocol + '/' + window.location.host + '/';
         $(element).removeClass('unread');
         var unreadCount = parseInt($('#unreadCount').html());
         unreadCount--;

         if (unreadCount <= 0) {
             $('#unreadCount').hide();
         }
         else {
             $('#unreadCount').html(unreadCount);
         }
         window.open(`${baseUrl}${url}`, "_blank");
         $.post('/UserProfile/MarkNotificationAsRead',
            {id: notificationId},
            function (result) {});
    }

    function MarkAllNotificationsAsRead() {
        $('#markAllAsRead').click(false);
        $.post('/UserProfile/MarkAllNotificationsAsRead', function (result) {
            $('#unreadCount').hide();
            $('#notificationsDropdown span').removeClass('unread');
            $('tr.unread').removeClass('unread');
        }
        );
    }

    function CalculateDateDifference(date1, date2) {
        var diff = Math.floor(date1.getTime() - date2.getTime());
        var hour = 1000 * 60 * 60;
        var day = 1000 * 60 * 60 * 24;

        var hours = Math.floor(diff / hour);
        var days = Math.floor(diff / day);
        var months = Math.floor(days / 31);
        var years = Math.floor(months / 12);

        return { Hours: hours,Days: days,Months: months,Years: years };
    }

    function RenderTimeAgoMessage(notificationCreatedOn) {
        var dateDifference = CalculateDateDifference(new Date(), new Date(parseInt(notificationCreatedOn.substring(6).replace(')/', '')))); //date parsing mega hack
        var timeDifferenceMessage = '';

        if (dateDifference.Hours < 24) {
            //less than a day
            timeDifference = dateDifference.Hours;

            if (timeDifference == 0) {
                //less than an hour ago
                timeDifferenceMessage = 'Less Than An Hour Ago';
            }
            else {
                var timeAgoMessage = 'Hours Ago';

                if (timeDifference == 1) {
                    timeAgoMessage = 'Hour Ago';
                }

                //x hours ago
                timeDifferenceMessage = `${timeDifference} ${timeAgoMessage}`;
            }

        }
        else {

            if (dateDifference.Days <= 30) {
                //less than a month
                timeDifference = dateDifference.Days;

                var timeAgoMessage = 'Days Ago';

                if (dateDifference == 1) {
                    timeAgoMessage = 'Day Ago';
                }

                //x hours ago
                timeDifferenceMessage = `${timeDifference} ${timeAgoMessage}`;
            }
            else {
                if (dateDifference.Months < 12) {
                    //less than a year
                    timeDifference = Math.floor(dateDifference.Months);

                    var timeAgoMessage = 'Months Ago';

                    if (timeDifference == 1) {
                        timeAgoMessage = 'Month Ago';
                    }

                    timeDifferenceMessage = `${timeDifference} ${timeAgoMessage}`;
                }
                else {
                    timeDifference = dateDifference.Years; //years

                    var timeAgoMessage = 'Years Ago';

                    if (timeDifference == 1) {
                        timeAgoMessage = 'Year Ago';
                    }

                    timeDifferenceMessage = `${timeDifference} ${timeAgoMessage}`;
                }
            }
        }
        return timeDifferenceMessage;
    }

    function displayNotifications(data) {
        if (data.length == 0 || data.Notifications == undefined)
            return;

        var unreadCount = data.UnreadCount;

        for (var i = data.Notifications.length - 1; i >= 0; i--) {

            var model = {
                Id: data.Notifications[i].Id,
                SnapshotUrl: data.Notifications[i].SnapshotUrl,
                UnreadClass: data.Notifications[i].IsRead == false ? 'unread' : '',
                DocumentName: data.Notifications[i].DocumentName
            };

            switch (data.Notifications[i].NotificationType) {
                case 2: model.Status = 'published'; break;
                case 1: model.Status = 'repealed'; break;
                case 0: model.Status = 'aġġornat'; break;
                case 3: model.Status = 'consolidated'; break;

            }

            model.TimeDifferenceMessage = RenderTimeAgoMessage(data.Notifications[i].CreatedOn);

            var notificationElement = `
                        <span onclick="MarkAsReadAndViewDocument(this, '${model.Id}','${model.SnapshotUrl}')" style="cursor:pointer; max-width: 400px;" class="flex-wrap ${model.UnreadClass}">
                            <div class="media">
                                <div class="media-body">
                                    <p class="text-sm p-2 m-2" style="width: 360px; font-style:italic;">
                                        ${model.DocumentName} <span style="font-style:normal;">was ${model.Status}</span>
                                    </p>
                                    <p class="text-sm text-muted p-2 m-2">
                                        <i class="far fa-clock mr-1"></i>
                                        ${model.TimeDifferenceMessage}
                                    </p>
                                </div>
                            </div>
                        </span>`;

            $('<div class="dropdown-divider"></div>').prependTo('#notificationsDropdown');
            $(notificationElement).prependTo("#notificationsDropdown");
            $('#notificationsSection').show();
        }
        if (unreadCount == 0) {
            $('#unreadCount').hide();
        }
        $('#unreadCount').html(unreadCount);
    }

    function CheckForNotifications() {
        var user = '';

            
                user = '';
            

        if (user == '')
            return;

        $.post(
            '/UserProfile/GetUserNotifications',
            {
                UserProfileId: user,
                Quantity: 5
            },
            function (data) {
                displayNotifications(data);
            }
        );
    }
</script>