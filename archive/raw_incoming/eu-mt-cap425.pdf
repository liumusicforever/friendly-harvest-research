<script>
    
    $(function () {

        //Click evnet for sidepanel header buttons.
        $(".button.truncate-text").click(function () {

            $(".sidePanelList").each(function () {

                if (!$(this).hasClass("d-none")) {
                    $(this).addClass("d-none");
                }
            });

            //Remove '.d-none' from element we want to see.
            var openTab = $(this).attr("data-href");
            $(openTab).removeClass("d-none");

            //Remove '.blue' from all side panel buttons then add to this one.
            $("#sidePanelOptions .button").removeClass("blue");
            $(this).addClass("blue");

        });

        //Click event for sidepanel 'relation' items.
        $("#sidePanelList_Relations a.header").click(function () {

            var dataLink = $(this).attr("data-link");

            if (dataLink !== "") {

                var pathName = $(this).attr("data-link");
                var newWindowLink = `${window.origin}/${pathName}`;
                window.open(newWindowLink, "_blank")
            }
        });

        $(window).resize(function () {
            updateSidepanelMaxHeight();
        });

        updateSidepanelMaxHeight();
    });

    //Set correct max-height;
    function updateSidepanelMaxHeight() {

        var element = $("#the-canvas").length === 0 ?
                        $("#htmlView") :
                        $("#the-canvas");

        var htmlHeight = parseFloat($(element).css("height").replace("px", ""));
        var extraHeight = parseFloat($("#htmlSidePanelToggleBtnContainer").css("height").replace("px", "")) + parseFloat($("#infoPanel").css("height").replace("px", ""));
        var targetHeight = htmlHeight - extraHeight;
        $(".scroll").css("max-height", targetHeight + "px");
    }


</script>
