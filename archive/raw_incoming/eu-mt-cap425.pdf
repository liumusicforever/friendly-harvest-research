    function renameKeywordElement() {

        var showLabel = "[Show]";
        var hideLabel = "[Hide]";

        //Toggle label value.
        $("#expandKeywordHref").text() === showLabel ?
            $("#expandKeywordHref").text(hideLabel) :
            $("#expandKeywordHref").text(showLabel)

        $(".keyword").toggleClass("d-none");
    }



    function unfollowKeyword(keywordId) {
        $(`i[data-follow="${keywordId}"]`).show();
        $(`i[data-unfollow="${keywordId}"]`).hide();
        $.ajax({
            type: "POST",
            url: '/UserProfile/unfollowKeyword',
            data: { id: keywordId, userId: `` },
            success: function (result) {
            },
            error: function (xhr, ajaxOptions, thrownError) {
                $(`i[data-follow="${keywordId}"]`).hide();
                $(`i[data-unfollow="${keywordId}"]`).show();
            }
        });
    }

    function followKeyword(keywordId) {
        $(`i[data-follow="${keywordId}"]`).hide();
        $(`i[data-unfollow="${keywordId}"]`).show();
        $.ajax({
            type: "POST",
            url: '/UserProfile/followKeyword',
            data: { id: keywordId, userId: `` },
            success: function (result) {
            },
            error: function (xhr, ajaxOptions, thrownError) {
                $(`i[data-follow="${keywordId}"]`).show();
                $(`i[data-unfollow="${keywordId}"]`).hide();
            }

        });
    }

